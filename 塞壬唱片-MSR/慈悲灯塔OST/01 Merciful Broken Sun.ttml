  <body dur="01:38.960">
    <div begin="01:09.950" end="01:38.960">
      <p begin="01:09.950" end="01:12.350" ttm:agent="v1" itunes:key="L1"><span begin="01:09.950" end="01:10.480">Bro</span><span begin="01:10.550" end="01:11.080">ken</span> <span begin="01:11.160" end="01:12.350">sun</span><span ttm:role="x-translation" xml:lang="zh-Hans">破碎的太阳</span><span ttm:role="x-translation" xml:lang="zh-Hant">破碎的太陽</span><span ttm:role="x-translation" xml:lang="ja">砕けた太陽</span><span ttm:role="x-translation" xml:lang="ko">부서진 태양</span><span ttm:role="x-translation" xml:lang="fr">Soleil brisé</span><span ttm:role="x-translation" xml:lang="es">Sol roto</span><span ttm:role="x-translation" xml:lang="de">Zerbrochene Sonne</span><span ttm:role="x-translation" xml:lang="pt">Sol despedaçado</span><span ttm:role="x-translation" xml:lang="ru">Разбитое солнце</span><span ttm:role="x-translation" xml:lang="it">Sole infranto</span></p>
      <p begin="01:13.440" end="01:17.390" ttm:agent="v1" itunes:key="L2"><span begin="01:13.440" end="01:13.670">Sh</span><span begin="01:13.670" end="01:13.860">ed</span><span begin="01:13.860" end="01:14.080">ding</span> <span begin="01:14.080" end="01:14.470">ligh</span><span begin="01:14.470" end="01:14.530">t</span> <span begin="01:14.530" end="01:14.870">on</span> <span begin="01:14.910" end="01:15.340">e</span><span begin="01:15.340" end="01:15.440">ve</span><span begin="01:15.440" end="01:16.080">ry</span><span begin="01:16.080" end="01:17.390">one</span><span ttm:role="x-translation" xml:lang="zh-Hans">将光芒照拂每一个生灵</span><span ttm:role="x-translation" xml:lang="zh-Hant">將光芒照拂每一個生靈</span><span ttm:role="x-translation" xml:lang="ja">全ての人を照らし出す</span><span ttm:role="x-translation" xml:lang="ko">모든 이를 비춰주네</span><span ttm:role="x-translation" xml:lang="fr">Éclairant tout le monde</span><span ttm:role="x-translation" xml:lang="es">Derramando luz sobre todos</span><span ttm:role="x-translation" xml:lang="de">Die Licht auf alle wirft</span><span ttm:role="x-translation" xml:lang="pt">Derramando luz sobre todos</span><span ttm:role="x-translation" xml:lang="ru">Проливающее свет на всех</span><span ttm:role="x-translation" xml:lang="it">Spargendo luce su tutti</span></p>
      <p begin="01:19.670" end="01:22.200" ttm:agent="v1" itunes:key="L3"><span begin="01:19.670" end="01:20.190">Bro</span><span begin="01:20.270" end="01:20.800">ken</span> <span begin="01:20.870" end="01:22.200">sun</span><span ttm:role="x-translation" xml:lang="zh-Hans">破碎的太阳</span><span ttm:role="x-translation" xml:lang="zh-Hant">破碎的太陽</span><span ttm:role="x-translation" xml:lang="ja">砕けた太陽</span><span ttm:role="x-translation" xml:lang="ko">부서진 태양</span><span ttm:role="x-translation" xml:lang="fr">Soleil brisé</span><span ttm:role="x-translation" xml:lang="es">Sol roto</span><span ttm:role="x-translation" xml:lang="de">Zerbrochene Sonne</span><span ttm:role="x-translation" xml:lang="pt">Sol despedaçado</span><span ttm:role="x-translation" xml:lang="ru">Разбитое солнце</span><span ttm:role="x-translation" xml:lang="it">Sole infranto</span></p>
      <p begin="01:23.300" end="01:27.200" ttm:agent="v1" itunes:key="L4"><span begin="01:23.300" end="01:23.560">You</span> <span begin="01:23.560" end="01:23.770">are</span> <span begin="01:23.770" end="01:24.100">not</span> <span begin="01:24.170" end="01:24.610">the</span> <span begin="01:24.610" end="01:25.120">on</span><span begin="01:25.120" end="01:25.730">ly</span> <span begin="01:25.730" end="01:27.200">one</span><span ttm:role="x-translation" xml:lang="zh-Hans">你并不是孤身一人</span><span ttm:role="x-translation" xml:lang="zh-Hant">你並不是孤身一人</span><span ttm:role="x-translation" xml:lang="ja">あなたは一人ではない</span><span ttm:role="x-translation" xml:lang="ko">너만 홀로 남겨진 게 아니야</span><span ttm:role="x-translation" xml:lang="fr">Tu n'es pas la seule</span><span ttm:role="x-translation" xml:lang="es">No eres la única</span><span ttm:role="x-translation" xml:lang="de">Du bist nicht die Einzige</span><span ttm:role="x-translation" xml:lang="pt">Você não é a única</span><span ttm:role="x-translation" xml:lang="ru">Ты не одиноко</span><span ttm:role="x-translation" xml:lang="it">Non sei il solo</span></p>
      <p begin="01:29.720" end="01:34.120" ttm:agent="v1" itunes:key="L5"><span begin="01:29.720" end="01:30.200">Whoa-</span><span begin="01:30.200" end="01:30.430">oh-</span><span begin="01:30.430" end="01:30.920">oh</span> <span begin="01:30.950" end="01:31.250">they</span> <span begin="01:31.340" end="01:31.670">can't</span> <span begin="01:31.750" end="01:32.120">take</span> <span begin="01:32.260" end="01:32.850">my</span> <span begin="01:32.850" end="01:32.970">s</span><span begin="01:33.030" end="01:34.090">par</span><span begin="01:34.090" end="01:34.120">k</span><span ttm:role="x-translation" xml:lang="zh-Hans">喔 他们无法夺走我的星火</span><span ttm:role="x-translation" xml:lang="zh-Hant">喔 他們無法奪走我的星火</span><span ttm:role="x-translation" xml:lang="ja">ああ 私の灯火は誰にも奪えはしない</span><span ttm:role="x-translation" xml:lang="ko">워어어, 그 누구도 내 불꽃을 빼앗을 순 없어</span><span ttm:role="x-translation" xml:lang="fr">Oh-oh-oh ils ne peuvent me prendre mon étincelle</span><span ttm:role="x-translation" xml:lang="es">Whoa-oh-oh no pueden quitarme mi chispa</span><span ttm:role="x-translation" xml:lang="de">Whoa-oh-oh sie können mir meinen Funken nicht rauben</span><span ttm:role="x-translation" xml:lang="pt">Whoa-oh-oh eles não podem levar a minha centelha</span><span ttm:role="x-translation" xml:lang="ru">Во-о-о им не отнять мою искру</span><span ttm:role="x-translation" xml:lang="it">Whoa-oh-oh non possono portarmi via la scintilla</span></p>
      <p begin="01:34.570" end="01:38.960" ttm:agent="v1" itunes:key="L6"><span begin="01:34.570" end="01:34.930">I</span> <span begin="01:34.930" end="01:35.390">won't</span> <span begin="01:35.390" end="01:35.710">le</span><span begin="01:35.780" end="01:35.860">t</span> <span begin="01:35.860" end="01:36.150">you</span> <span begin="01:36.220" end="01:36.580">go</span> <span begin="01:36.620" end="01:38.960">dark</span><span ttm:role="x-translation" xml:lang="zh-Hans">我也绝不会让你坠入黑暗</span><span ttm:role="x-translation" xml:lang="zh-Hant">我也絕不會讓你墜入黑暗</span><span ttm:role="x-translation" xml:lang="ja">あなたを暗闇に沈ませはしない</span><span ttm:role="x-translation" xml:lang="ko">네 빛이 꺼지게 두지 않을 거야</span><span ttm:role="x-translation" xml:lang="fr">Je ne te laisserai pas t'éteindre</span><span ttm:role="x-translation" xml:lang="es">No dejaré que te apagues</span><span ttm:role="x-translation" xml:lang="de">Ich lasse dich nicht erlöschen</span><span ttm:role="x-translation" xml:lang="pt">Não deixarei você se apagar</span><span ttm:role="x-translation" xml:lang="ru">Я не позволю тебе угаснуть</span><span ttm:role="x-translation" xml:lang="it">Non ti lascerò spegnere</span></p>
