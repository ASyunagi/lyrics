      <p begin="01:22.210" end="01:25.080" ttm:agent="v1" itunes:key="L17"><span begin="01:22.210" end="01:22.380">You</span> <span begin="01:22.400" end="01:22.590">were</span> <span begin="01:22.630" end="01:23.110">right</span> <span begin="01:23.170" end="01:23.600">here</span> <span begin="01:23.600" end="01:23.730">all</span> <span begin="01:23.730" end="01:23.830">a</span><span begin="01:23.970" end="01:25.080">long</span><span ttm:role="x-translation" xml:lang="zh-CN">你一直都在这里</span></p>
      <p begin="01:26.500" end="01:28.160" ttm:agent="v1" itunes:key="L18"><span begin="01:26.500" end="01:26.590">I</span><span begin="01:26.590" end="01:26.670">t's</span> <span begin="01:26.700" end="01:26.830">li</span><span begin="01:26.880" end="01:26.910">ke</span> <span begin="01:26.910" end="01:27.040">you're</span> <span begin="01:27.100" end="01:27.240">my</span> <span begin="01:27.300" end="01:27.820">mir</span><span begin="01:27.880" end="01:28.160">ror</span><span ttm:role="x-translation" xml:lang="zh-CN">宛如你是我的明镜</span><span ttm:role="x-bg" begin="01:28.640" end="01:29.040"><span begin="01:28.640" end="01:29.040">(Oh)</span><span ttm:role="x-translation" xml:lang="zh-CN">噢</span></span></p>
      <p begin="01:29.410" end="01:31.400" ttm:agent="v1" itunes:key="L19"><span begin="01:29.410" end="01:29.580">My</span> <span begin="01:29.630" end="01:29.780">mir</span><span begin="01:29.810" end="01:29.910">ror</span> <span begin="01:29.930" end="01:30.000">s</span><span begin="01:30.030" end="01:30.190">ta</span><span begin="01:30.190" end="01:30.340">ring</span> <span begin="01:30.400" end="01:30.570">ba</span><span begin="01:30.610" end="01:30.640">ck</span> <span begin="01:30.640" end="01:30.730">at</span> <span begin="01:30.820" end="01:31.400">me</span><span ttm:role="x-translation" xml:lang="zh-CN">我的明镜正凝视着我</span><span ttm:role="x-bg" begin="01:31.760" end="01:33.660"><span begin="01:31.760" end="01:32.080">(Oh</span> <span begin="01:32.540" end="01:32.860">Oh</span> <span begin="01:33.310" end="01:33.660">Oh)</span><span ttm:role="x-translation" xml:lang="zh-CN">噢 噢 噢</span></span></p>
      <p begin="01:32.330" end="01:34.360" ttm:agent="v1" itunes:key="L20"><span begin="01:32.330" end="01:32.490">I</span> <span begin="01:32.530" end="01:32.740">coul</span><span begin="01:32.740" end="01:32.880">dn't</span> <span begin="01:32.930" end="01:33.120">ge</span><span begin="01:33.120" end="01:33.150">t</span> <span begin="01:33.150" end="01:33.310">a</span><span begin="01:33.310" end="01:33.450">ny</span> <span begin="01:33.510" end="01:34.070">big</span><span begin="01:34.110" end="01:34.360">ger</span><span ttm:role="x-translation" xml:lang="zh-CN">我无法变得更强大</span><span ttm:role="x-bg" begin="01:34.870" end="01:35.270"><span begin="01:34.870" end="01:35.270">(Oh)</span><span ttm:role="x-translation" xml:lang="zh-CN">噢</span></span></p>
